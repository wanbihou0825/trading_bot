# Polymarket 跟单机器人配置
# 复制此文件为 .env 并填写实际值

# === 必需配置 ===

# Polygon RPC URL (主节点)
POLYGON_RPC_URL=https://polygon-rpc.com

# 钱包私钥 (64位十六进制，可带0x前缀)
# 警告: 永远不要分享你的私钥！
PRIVATE_KEY=your_private_key_here

# 钱包地址 (0x开头的42位地址)
WALLET_ADDRESS=0xYourWalletAddressHere

# Polygonscan API Key (跟单功能必需，用于获取钱包交易历史)
# 获取地址: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# === 可选配置 ===

# Polymarket API URL
POLYMARKET_API_URL=https://clob.polymarket.com

# WebSocket URLs
# Polymarket 市场数据 WebSocket (留空使用默认值)
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# 钱包监控 WebSocket (Polygonscan 不支持 WebSocket，留空使用轮询模式)
WALLET_MONITOR_WS_URL=

# 运行模式 (true=模拟模式, false=实盘)
DRY_RUN=true

# Telegram 通知 (可选)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === 风险管理配置 ===

# 每日最大损失 (USD)
MAX_DAILY_LOSS=100

# 单笔最大仓位 (USD)
MAX_POSITION_SIZE=50

# 最大仓位占余额比例
MAX_POSITION_PCT=0.03

# 最大并发仓位数
MAX_CONCURRENT_POSITIONS=5

# 最大总敞口 (USD) - 所有持仓价值之和的上限
MAX_TOTAL_EXPOSURE=200

# === Endgame Sweeper 配置 ===

# 最小入场概率
ENDGAME_MIN_PROB=0.95

# 最大距离结算天数
ENDGAME_MAX_DAYS=7

# 最小日流动性 (USD)
ENDGAME_MIN_LIQUIDITY=10000

# === 多RPC提供商配置 (生产级failover) ===

# 备用RPC节点 (逗号分隔，自动failover)
# Alchemy: https://polygon.alchemyapi.io/v2/YOUR_KEY
# QuickNode: https://polygon.quicknode.com/YOUR_KEY
# Ankr: https://rpc.ankr.com/polygon
BACKUP_RPC_URLS=

# 备用WebSocket节点 (逗号分隔)
BACKUP_WS_URLS=

# === Gas配置 (动态优化) ===

# Gas价格上限 (Gwei)
MAX_GAS_PRICE=100

# 优先费用 (Gwei) - EIP-1559
PRIORITY_FEE=2

# Gas war时自动上调优先费用 (倍数)
GAS_WAR_MULTIPLIER=2.0

# === 监控告警配置 ===

# 心跳间隔 (秒)
HEARTBEAT_INTERVAL=300

# 余额检查间隔 (秒)
BALANCE_CHECK_INTERVAL=300

# 余额异常阈值 (百分比，如-10%表示余额下降10%触发告警)
BALANCE_ALERT_THRESHOLD=-0.10

# === Slippage/价格保护 ===

# 最大滑点容忍度 (百分比)
MAX_SLIPPAGE=0.03

# 最大价格偏差 (下单前检查，超过则取消)
MAX_PRICE_DEVIATION=0.05

# === 日志配置 ===

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=logs

# 是否启用JSON格式日志
ENABLE_JSON_LOGS=true

# 单个日志文件最大大小 (MB)
LOG_MAX_SIZE=10

# 保留日志文件数量
LOG_BACKUP_COUNT=5
