# Polymarket 跟单机器人配置
# 复制此文件为 .env 并填写实际值

# ══════════════════════════════════════════════════════
# 必需配置 (不填无法启动)
# ══════════════════════════════════════════════════════

# Polygon RPC URL (主节点)
# 免费: https://polygon-rpc.com
# 推荐: Alchemy/QuickNode/Ankr 付费节点 (更稳定)
POLYGON_RPC_URL=https://polygon-rpc.com

# 钱包私钥 (64位十六进制，可带0x前缀)
# ⚠️ 警告: 永远不要分享你的私钥！
# 用于 L2 API 认证，客户端会通过 py-clob-client 自动派生 API credentials
PRIVATE_KEY=your_private_key_here

# MetaMask EOA 地址 (0x开头的42位地址，用于签名)
WALLET_ADDRESS=0xYourWalletAddressHere

# Proxy 钱包地址 (Gnosis Safe 模式必需)
# 资金实际存放位置（USDC 余额、仓位均在此地址）
# 获取方式: 登录 polymarket.com → 右上角头像 → Settings → Wallet Address
# 配置此项后自动使用 Gnosis Safe 模式 (signature_type=2)
# 留空则使用 EOA 模式 (signature_type=0)
FUNDER_ADDRESS=0xYourProxyAddressHere

# Polygonscan API Key (钱包扫描必需)
# 获取: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ══════════════════════════════════════════════════════
# 运行模式
# ══════════════════════════════════════════════════════

# true=模拟模式 (不下真实订单), false=实盘
# ⚠️ 首次运行务必使用 true
DRY_RUN=true

# ══════════════════════════════════════════════════════
# Polymarket API 配置 (通常保持默认即可)
# ══════════════════════════════════════════════════════

# CLOB API (交易执行)
POLYMARKET_API_URL=https://clob.polymarket.com

# 签名类型 (0=EOA, 1=Poly Proxy, 2=Gnosis Safe)
# 配置了 FUNDER_ADDRESS 后一般不需要手动设置
# POLYMARKET_SIGNATURE_TYPE=2

# Chain ID (137=Mainnet)
POLYMARKET_CHAIN_ID=137

# ══════════════════════════════════════════════════════
# 跟单配置
# ══════════════════════════════════════════════════════

# 启用跟单
COPY_TRADING_ENABLED=true

# 自动发现高质量钱包 (4个数据源: 排行榜/CLOB活跃/Polygonscan/种子钱包)
COPY_AUTO_DISCOVER=true

# 跟单模式: smart(智能)/fixed(固定金额)/proportional(比例)/full(全额)
COPY_TRADING_MODE=smart

# 固定金额跟单 (USD) - fixed/smart模式下的基准金额
COPY_FIXED_AMOUNT=10

# 比例跟单 (0.1=目标金额的10%) - proportional模式
COPY_PROPORTIONAL_RATIO=0.1

# 跟单金额范围 (USD)
COPY_MAX_AMOUNT=50
COPY_MIN_AMOUNT=5

# 跟单延迟 (秒) - 避免被识别为跟单
COPY_DELAY_SECONDS=1.0

# 最大同时跟单钱包数
COPY_MAX_WALLETS=10

# 是否跟平仓 (关键! 避免持仓失控)
COPY_FOLLOW_CLOSE=true

# 目标平仓时自动平仓
COPY_CLOSE_ON_TARGET_CLOSE=true

# 持仓同步间隔 (秒) - 检测遗漏的平仓信号
COPY_POSITION_SYNC_INTERVAL=60

# 目标钱包列表 (逗号分隔, auto_discover=true时可留空)
TARGET_WALLETS=

# 种子钱包列表 (已知优质钱包，优先分析，与自动发现并行工作)
# 可通过 Polymarket 排行榜手动找到高质量交易者地址
SEED_WALLETS=

# ══════════════════════════════════════════════════════
# 钱包质量评分门槛
# ══════════════════════════════════════════════════════

# 最小交易次数 (过滤样本不足的钱包)
WALLET_MIN_TRADES=20

# 最小胜率 (0.55=55%)
WALLET_MIN_WIN_RATE=0.55

# 最小盈亏比 (总利润/总亏损)
WALLET_MIN_PROFIT_FACTOR=1.2

# 最小质量评分 (0-100)
WALLET_MIN_QUALITY_SCORE=70

# ══════════════════════════════════════════════════════
# 风险管理配置
# ══════════════════════════════════════════════════════

# 每日最大损失 (USD) - 达到后触发熔断
MAX_DAILY_LOSS=100

# 单笔最大仓位 (USD)
MAX_POSITION_SIZE=50

# 最大仓位占余额比例 (0.03=3%)
MAX_POSITION_PCT=0.03

# 最大并发仓位数
MAX_CONCURRENT_POSITIONS=5

# 最大总敞口 (USD) - 所有持仓总值上限
MAX_TOTAL_EXPOSURE=200

# ══════════════════════════════════════════════════════
# Endgame Sweeper 策略配置
# ══════════════════════════════════════════════════════

# 最小入场概率 (0.95=95%)
ENDGAME_MIN_PROB=0.95

# 最大距离结算天数
ENDGAME_MAX_DAYS=7

# 最小日流动性 (USD)
ENDGAME_MIN_LIQUIDITY=10000

# ══════════════════════════════════════════════════════
# Telegram 通知 (可选)
# ══════════════════════════════════════════════════════

# Bot Token (通过 @BotFather 创建)
TELEGRAM_BOT_TOKEN=
# Chat ID (通过 @userinfobot 获取)
TELEGRAM_CHAT_ID=

# ══════════════════════════════════════════════════════
# WebSocket 配置
# ══════════════════════════════════════════════════════

# 启用 WebSocket 实时推送
WEBSOCKET_ENABLED=true

# Polymarket WebSocket URL
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# 钱包监控 WebSocket URL (可选, Polygon WS RPC)
WALLET_MONITOR_WS_URL=

# 重连间隔 (秒)
WS_RECONNECT_INTERVAL=5

# 最大重连次数
WS_MAX_RECONNECT=10

# ══════════════════════════════════════════════════════
# 多 RPC Failover (生产级)
# ══════════════════════════════════════════════════════

# 备用 RPC 节点 (逗号分隔，自动故障转移)
BACKUP_RPC_URLS=

# 备用 WebSocket 节点 (逗号分隔)
BACKUP_WS_URLS=

# Gas 价格上限 (Gwei)
MAX_GAS_PRICE=100

# 优先费用 (Gwei) - EIP-1559
PRIORITY_FEE=2

# Gas war时自动上调优先费用 (倍数)
GAS_WAR_MULTIPLIER=2.0

# === 监控告警配置 ===

# 心跳间隔 (秒)
HEARTBEAT_INTERVAL=300

# 余额检查间隔 (秒)
BALANCE_CHECK_INTERVAL=300

# 余额异常阈值 (百分比，如-10%表示余额下降10%触发告警)
BALANCE_ALERT_THRESHOLD=-0.10

# === Slippage/价格保护 ===

# 最大滑点容忍度 (百分比)
# 默认值已从 3% 收紧到 1%，根据流动性动态调整
MAX_SLIPPAGE=0.01

# 最大价格偏差 (下单前检查，超过则取消)
# 默认值已从 5% 收紧到 3%
MAX_PRICE_DEVIATION=0.03

# 最小流动性阈值 (USD)
SLIPPAGE_MIN_LIQUIDITY=10000

# 启用动态滑点调整 (根据流动性自动调整)
SLIPPAGE_DYNAMIC=true

# === 跟单模式配置 ===

# 是否启用跟单
COPY_TRADING_ENABLED=true

# 自动发现高质量钱包 (无需手动配置目标钱包)
COPY_AUTO_DISCOVER=true

# 跟单模式 (smart=智能, fixed=固定金额, proportional=比例, full=全额)
# smart: 根据钱包质量智能调整金额（推荐）
# fixed: 每笔跟单固定金额
# proportional: 按比例跟单
# full: 全额跟单
COPY_TRADING_MODE=smart

# 固定金额模式下的跟单金额 (USD)
COPY_FIXED_AMOUNT=10

# 比例跟单模式下的跟单比例 (如 0.1 表示跟单 10%)
COPY_PROPORTIONAL_RATIO=0.1

# 单笔跟单最大金额 (USD)
COPY_MAX_AMOUNT=50

# 单笔跟单最小金额 (USD)
COPY_MIN_AMOUNT=5

# 跟单延迟 (秒) - 跟单前等待时间
COPY_DELAY_SECONDS=1.0

# 是否跟平仓 (避免持仓失控的关键配置!)
COPY_FOLLOW_CLOSE=true

# 目标平仓时自动平仓
COPY_CLOSE_ON_TARGET_CLOSE=true

# 持仓同步间隔 (秒) - 定期检查目标持仓，自动平仓未跟踪的仓位
# 建议值: 60-600 (1-10分钟)
# 较低值 = 更及时的平仓，但更多 API 调用
# 较高值 = 较少的 API 调用，但可能延迟平仓
COPY_POSITION_SYNC_INTERVAL=300

# 最大跟单钱包数
COPY_MAX_WALLETS=10

# 目标钱包列表 (可选，逗号分隔，auto_discover=True 时可留空)
# 示例: TARGET_WALLETS=0xWallet1,0xWallet2,0xWallet3
TARGET_WALLETS=

# === 交易持久化配置 (新增) ===

# 交易数据库路径
TRADE_DB_PATH=data/trades.db

# 清理旧记录天数 (30天)
TRADE_RETENTION_DAYS=30

# === 日志配置 ===

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=logs

# 是否启用JSON格式日志
ENABLE_JSON_LOGS=true

# 单个日志文件最大大小 (MB)
LOG_MAX_SIZE=10

# 保留日志文件数量
LOG_BACKUP_COUNT=5

# === 依赖说明 ===

# Python 3.10+ 必需的依赖:
# - web3 >= 6.0.0 (区块链交互)
# - eth_account >= 0.10.0 (L2 API 签名)
# - aiohttp >= 3.9.0 (异步 HTTP)
# - pydantic >= 2.0.0 (数据验证)
# - python-dotenv >= 1.0.0 (环境变量)
#
# 安装命令:
# pip install -r requirements.txt
