# Polymarket 跟单机器人配置
# 复制此文件为 .env 并填写实际值

# === 必需配置 ===

# Polygon RPC URL (可以使用公共RPC或私有节点)
POLYGON_RPC_URL=https://polygon-rpc.com

# 钱包私钥 (64位十六进制，可带0x前缀)
# 警告: 永远不要分享你的私钥！
PRIVATE_KEY=your_private_key_here

# 钱包地址 (0x开头的42位地址)
WALLET_ADDRESS=0xYourWalletAddressHere

# === 可选配置 ===

# Polymarket API URL
POLYMARKET_API_URL=https://clob.polymarket.com

# WebSocket URLs
# Polymarket 市场数据 WebSocket (留空使用默认值)
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# 钱包监控 WebSocket (Polygonscan 不支持 WebSocket，留空使用轮询模式)
WALLET_MONITOR_WS_URL=

# 运行模式 (true=模拟模式, false=实盘)
DRY_RUN=true

# Telegram 通知 (可选)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === 风险管理配置 ===

# 每日最大损失 (USD)
MAX_DAILY_LOSS=100

# 单笔最大仓位 (USD)
MAX_POSITION_SIZE=50

# 最大仓位占余额比例
MAX_POSITION_PCT=0.03

# 最大并发仓位数
MAX_CONCURRENT_POSITIONS=5

# 最大总敞口 (USD) - 所有持仓价值之和的上限
MAX_TOTAL_EXPOSURE=200

# === Endgame Sweeper 配置 ===

# 最小入场概率
ENDGAME_MIN_PROB=0.95

# 最大距离结算天数
ENDGAME_MAX_DAYS=7

# 最小日流动性 (USD)
ENDGAME_MIN_LIQUIDITY=10000
