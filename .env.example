# Polymarket 跟单机器人配置
# 复制此文件为 .env 并填写实际值

# ══════════════════════════════════════════════════════
# 必需配置 (不填无法启动)
# ══════════════════════════════════════════════════════

# Polygon RPC URL (主节点)
# 免费: https://polygon-rpc.com
# 推荐: Alchemy/QuickNode/Ankr 付费节点 (更稳定)
POLYGON_RPC_URL=https://polygon-rpc.com

# 钱包私钥 (64位十六进制，可带0x前缀)
# ⚠️ 警告: 永远不要分享你的私钥！
# 用于 L2 API 认证，客户端会通过 py-clob-client 自动派生 API credentials
PRIVATE_KEY=your_private_key_here

# MetaMask EOA 地址 (0x开头的42位地址，用于签名)
WALLET_ADDRESS=0xYourWalletAddressHere

# Proxy 钱包地址 (Gnosis Safe 模式必需)
# 资金实际存放位置（USDC 余额、仓位均在此地址）
# 获取方式: 登录 polymarket.com → 右上角头像 → Settings → Wallet Address
# 配置此项后自动使用 Gnosis Safe 模式 (signature_type=2)
# 留空则使用 EOA 模式 (signature_type=0)
FUNDER_ADDRESS=0xYourProxyAddressHere

# Polygonscan API Key (可选 - 辅助钱包发现，核心监控已改用 Data API)
# V1 已废弃，留空即可，不影响主要功能
POLYGONSCAN_API_KEY=

# ══════════════════════════════════════════════════════
# 运行模式
# ══════════════════════════════════════════════════════

# true=模拟模式 (不下真实订单), false=实盘
# ⚠️ 首次运行务必使用 true
DRY_RUN=true

# ══════════════════════════════════════════════════════
# Polymarket API 配置 (通常保持默认即可)
# ══════════════════════════════════════════════════════

# CLOB API (交易执行)
POLYMARKET_API_URL=https://clob.polymarket.com

# 签名类型 (0=EOA, 1=Poly Proxy, 2=Gnosis Safe)
# 配置了 FUNDER_ADDRESS 后一般不需要手动设置
# POLYMARKET_SIGNATURE_TYPE=2

# ══════════════════════════════════════════════════════
# 跟单配置
# ══════════════════════════════════════════════════════

# 启用跟单
COPY_TRADING_ENABLED=true

# 自动发现高质量钱包 (数据源: 官方排行榜 API + 种子钱包)
COPY_AUTO_DISCOVER=true

# 跟单模式: smart(智能)/fixed(固定金额)/proportional(比例)/full(全额)
COPY_TRADING_MODE=smart

# 固定金额跟单 (USD) - fixed/smart模式下的基准金额
COPY_FIXED_AMOUNT=10

# 比例跟单 (0.1=目标金额的10%) - proportional模式
COPY_PROPORTIONAL_RATIO=0.1

# 跟单金额范围 (USD)
COPY_MAX_AMOUNT=50
COPY_MIN_AMOUNT=5

# 跟单延迟 (秒) - 避免被识别为跟单
COPY_DELAY_SECONDS=1.0

# 最大同时跟单钱包数
COPY_MAX_WALLETS=10

# 排行榜扫描钱包数 (从官方排行榜前 N 名中筛选)
COPY_MAX_SCAN_WALLETS=100

# 是否跟平仓 (关键! 避免持仓失控)
COPY_FOLLOW_CLOSE=true

# 目标平仓时自动平仓
COPY_CLOSE_ON_TARGET_CLOSE=true

# 持仓同步间隔 (秒) - 检测遗漏的平仓信号
COPY_POSITION_SYNC_INTERVAL=300

# 目标钱包列表 (逗号分隔, auto_discover=true时可留空)
TARGET_WALLETS=

# 种子钱包列表 (已知优质钱包，优先分析，与自动发现并行工作)
# 可通过 Polymarket 排行榜手动找到高质量交易者地址
SEED_WALLETS=

# ══════════════════════════════════════════════════════
# 钱包质量评分门槛
# ══════════════════════════════════════════════════════

# 最小交易次数 (过滤样本不足的钱包)
WALLET_MIN_TRADES=20

# 最小胜率 (0.55=55%)
WALLET_MIN_WIN_RATE=0.55

# 最小盈亏比 (总利润/总亏损)
WALLET_MIN_PROFIT_FACTOR=1.2

# 最小质量评分 (0-10分制, 7.0=expert级以上)
WALLET_MIN_QUALITY_SCORE=7.0

# ══════════════════════════════════════════════════════
# 风险管理配置
# ══════════════════════════════════════════════════════

# 每日最大损失 (USD) - 达到后触发熔断
MAX_DAILY_LOSS=100

# 单笔最大仓位 (USD)
MAX_POSITION_SIZE=50

# 最大仓位占余额比例 (0.03=3%)
MAX_POSITION_PCT=0.03

# 最大并发仓位数
MAX_CONCURRENT_POSITIONS=5

# 最大总敞口 (USD) - 所有持仓总值上限
MAX_TOTAL_EXPOSURE=200
# 止损比例 (0.15=15%)
STOP_LOSS_PCT=0.15

# 止盈比例 (0.25=25%)
TAKE_PROFIT_PCT=0.25
# ══════════════════════════════════════════════════════
# Endgame Sweeper 策略配置
# ══════════════════════════════════════════════════════

# 最小入场概率 (0.95=95%)
ENDGAME_MIN_PROB=0.95

# 最大距离结算天数
ENDGAME_MAX_DAYS=7

# 最小日流动性 (USD)
ENDGAME_MIN_LIQUIDITY=10000

# ══════════════════════════════════════════════════════
# Telegram 通知 (可选)
# ══════════════════════════════════════════════════════

# Bot Token (通过 @BotFather 创建)
TELEGRAM_BOT_TOKEN=
# Chat ID (通过 @userinfobot 获取)
TELEGRAM_CHAT_ID=
# 配置后交易通知包含源钱包地址和交易详情

# ══════════════════════════════════════════════════════
# WebSocket 配置
# ══════════════════════════════════════════════════════

# 启用 WebSocket 实时推送
WEBSOCKET_ENABLED=true

# Polymarket WebSocket URL
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# 钱包监控 WebSocket URL (可选, Polygon WS RPC)
# 留空则自动回退到轮询模式 (可正常工作，延迟稍高)
# 注意: 钱包交易监控已改用 Polymarket Data API 轮询，此项仅用于市场数据推送
# Alchemy: wss://polygon-mainnet.g.alchemy.com/v2/<API_KEY>
# Infura:  wss://polygon-mainnet.infura.io/ws/v3/<PROJECT_ID>  (注意多了 /ws/)
WALLET_MONITOR_WS_URL=

# 重连间隔 (秒)
WS_RECONNECT_INTERVAL=5

# 最大重连次数
WS_MAX_RECONNECT=10

# ══════════════════════════════════════════════════════
# 多 RPC Failover (生产级)
# ══════════════════════════════════════════════════════

# 备用 RPC 节点 (逗号分隔，自动故障转移)
# 暂未实现，预留配置
# BACKUP_RPC_URLS=
